# Secret Garden Protocol — environment template.
# Copy to `.env` and fill in as needed. Never commit the real `.env` or any keypair.
#
# Stage 1 tests run on solana-bankrun (in-process) and require NONE of these.
# They are listed for later stages that talk to a real cluster.

# RPC endpoint Anchor/clients should use (localnet | devnet URL).
ANCHOR_PROVIDER_URL=http://127.0.0.1:8899

# Path to the wallet keypair used to pay for and sign transactions.
ANCHOR_WALLET=~/.config/solana/id.json
